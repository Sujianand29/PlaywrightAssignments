let num = -10
let num2=12
let num3=0

function numbySwitch(inputNum){
    switch (true) {
        case (inputNum>0):
            console.log("The number is greater than 0")           
            break;

        case (inputNum<0):
            console.log("The number is less than 0")
            break;

        case (inputNum === 0):
            console.log("The number is equal to 0")
            break;
        default:
            console.log("This will be executed by default if none of the conditions met - "+inputNum)
            break;
    }
}

function numbyIf(inputNum){
    if(inputNum > 0){
        console.log("The number is greater than 0")    
    }else if(inputNum < 0){
        console.log("The number is less than 0 " +inputNum);
    }else{
        console.log("inputNum is not a number")
    }
}
console.log("Executing Switch case")
numbySwitch(num)
numbySwitch(num2)
numbySwitch(num3)
console.log("--------------------------------------------------")
console.log("Executing If else")
numbyIf(num)
numbyIf(num2)
numbyIf(num3)
console.log("--------------------------------------------------")